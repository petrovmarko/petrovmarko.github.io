---
interface Props {
  title?: string;
}
const { title = "Marko Petrov" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Marko Petrov — Computer Science student. Deep learning, algorithms, and competitive programming." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:wght@400;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      ::selection { background: rgba(42, 122, 226, 0.18); }
      a { color: #2a7ae2; text-decoration: none; }
      a:hover { color: #1856a8; text-decoration: underline; }
      .section-heading {
        font-size: 1.5rem;
        font-weight: 700;
        color: #252a2e;
        text-decoration: underline;
        text-underline-offset: 4px;
        margin-bottom: 1.25rem;
        margin-top: 2.5rem;
      }
      .section-heading:first-of-type { margin-top: 0; }
      .entry-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #252a2e;
        margin-bottom: 0.25rem;
      }
      .entry-meta {
        margin-bottom: 0.25rem;
        line-height: 1.5;
      }
      .entry-links a + a::before {
        content: " | ";
        color: #8a8d93;
      }
    </style>
  </head>
  <body class="bg-bg text-text-primary font-sans antialiased">
    <slot />
  </body>
</html>
