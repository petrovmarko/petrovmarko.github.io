---
const entries: Array<{
  year: string;
  title: string;
  context?: string;
  href?: string;
}> = [
  {
    year: 'YYYY',
    title: 'Award name',
    context: 'Issuing body / competition / event',
  },
];
---

<section id="awards">
  <h1 class="section-heading">Awards:</h1>
  <ul class="award-list">
    {entries.map(a => (
      <li>
        <span class="award-year"><em>{a.year}</em></span>
        <span class="award-body">
          {a.href
            ? <a href={a.href} target="_blank" rel="noreferrer">{a.title}</a>
            : <strong>{a.title}</strong>
          }
          {a.context && <span class="award-context"> &mdash; {a.context}</span>}
        </span>
      </li>
    ))}
  </ul>
</section>

<style>
  .award-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .award-list > li {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 0.75rem;
    padding: 0.35rem 0;
    line-height: 1.55;
  }
  .award-year {
    color: #5e616a;
    font-size: 0.9rem;
    padding-top: 1px;
  }
  .award-body {
    color: #252a2e;
    font-size: 0.95rem;
  }
  .award-body strong {
    font-weight: 600;
  }
  .award-context {
    color: #5e616a;
  }
</style>
