---
const entries = [
  {
    period: 'YYYY – YYYY',
    role: 'Role / Title',
    org: 'Organization',
    location: 'City, Country',
    desc: 'One-line description of what you did and what you built.',
  },
];
---

<section id="experience">
  <h1 class="section-heading">Experience:</h1>
  <ul class="exp-list">
    {entries.map(e => (
      <li>
        <p class="exp-period"><em>{e.period}</em></p>
        <p class="exp-role">
          {e.role} &mdash; {e.org}
          {e.location && <span class="exp-location">, {e.location}</span>}
        </p>
        {e.desc && <p class="exp-desc">{e.desc}</p>}
      </li>
    ))}
  </ul>
</section>

<style>
  .exp-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .exp-list > li {
    padding: 0.5rem 0;
    margin-bottom: 0.75rem;
  }
  .exp-list > li:last-child { margin-bottom: 0; }

  .exp-period {
    color: #5e616a;
    font-size: 0.9rem;
    margin-bottom: 0.15rem;
  }
  .exp-role {
    color: #252a2e;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }
  .exp-location {
    font-weight: 400;
    color: #5e616a;
  }
  .exp-desc {
    color: #252a2e;
    font-size: 0.95rem;
    line-height: 1.55;
  }
</style>
