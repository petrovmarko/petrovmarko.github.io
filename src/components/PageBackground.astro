---
// Full-page topo background. Sits absolute inside <main>.
// viewBox is 1200 wide × 3200 tall — clusters distributed so each
// section of the page has topo contours visible behind it.
---

<div class="absolute inset-0 w-full h-full overflow-hidden pointer-events-none select-none z-0" aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="absolute top-0 left-0 w-full animate-topo-drift"
    style="height: 100%; min-height: 100%;"
    preserveAspectRatio="xMidYMin slice"
    viewBox="0 0 1200 3200"
  >
    <g stroke="#7a9ab8" fill="none">

      <!-- ═══ ZONE 1 — Hero (y: 0–550) ═══ -->
      <!-- Top-right dominant peak -->
      <ellipse cx="1100" cy="60"   rx="420" ry="300" stroke-width="1"   opacity="0.18"/>
      <ellipse cx="1100" cy="60"   rx="345" ry="242" stroke-width="1"   opacity="0.18"/>
      <ellipse cx="1100" cy="60"   rx="272" ry="188" stroke-width="1.5" opacity="0.20"/>
      <ellipse cx="1100" cy="60"   rx="202" ry="136" stroke-width="1"   opacity="0.18"/>
      <ellipse cx="1100" cy="60"   rx="136" ry="88"  stroke-width="1"   opacity="0.18"/>
      <ellipse cx="1100" cy="60"   rx="72"  ry="44"  stroke-width="1.5" opacity="0.22"/>

      <!-- Bottom-left shoulder -->
      <ellipse cx="100"  cy="520"  rx="260" ry="190" stroke-width="1"   opacity="0.15"/>
      <ellipse cx="100"  cy="520"  rx="198" ry="144" stroke-width="1.5" opacity="0.17"/>
      <ellipse cx="100"  cy="520"  rx="138" ry="98"  stroke-width="1"   opacity="0.15"/>
      <ellipse cx="100"  cy="520"  rx="82"  ry="56"  stroke-width="1"   opacity="0.15"/>

      <!-- ═══ ZONE 2 — Tools / Work (y: 550–1200) ═══ -->
      <!-- Far-right mid cluster -->
      <ellipse cx="1180" cy="900"  rx="300" ry="220" stroke-width="1"   opacity="0.16"/>
      <ellipse cx="1180" cy="900"  rx="236" ry="172" stroke-width="1.5" opacity="0.18"/>
      <ellipse cx="1180" cy="900"  rx="172" ry="124" stroke-width="1"   opacity="0.16"/>
      <ellipse cx="1180" cy="900"  rx="110" ry="78"  stroke-width="1"   opacity="0.16"/>
      <ellipse cx="1180" cy="900"  rx="56"  ry="38"  stroke-width="1.5" opacity="0.20"/>

      <!-- Left-center small peak -->
      <ellipse cx="80"   cy="1100" rx="190" ry="140" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="80"   cy="1100" rx="142" ry="104" stroke-width="1.5" opacity="0.16"/>
      <ellipse cx="80"   cy="1100" rx="96"  ry="68"  stroke-width="1"   opacity="0.14"/>
      <ellipse cx="80"   cy="1100" rx="52"  ry="36"  stroke-width="1"   opacity="0.14"/>

      <!-- ═══ ZONE 3 — Papers (y: 1200–2000) ═══ -->
      <!-- Large central ridge — most prominent, anchors the page -->
      <ellipse cx="600"  cy="1540" rx="500" ry="340" stroke-width="1"   opacity="0.13"/>
      <ellipse cx="600"  cy="1540" rx="408" ry="272" stroke-width="1"   opacity="0.13"/>
      <ellipse cx="600"  cy="1540" rx="318" ry="208" stroke-width="1.5" opacity="0.16"/>
      <ellipse cx="600"  cy="1540" rx="232" ry="150" stroke-width="1"   opacity="0.13"/>
      <ellipse cx="600"  cy="1540" rx="152" ry="96"  stroke-width="1"   opacity="0.13"/>
      <ellipse cx="600"  cy="1540" rx="78"  ry="48"  stroke-width="1.5" opacity="0.17"/>
      <ellipse cx="600"  cy="1540" rx="32"  ry="20"  stroke-width="1"   opacity="0.13"/>

      <!-- Top-right companion -->
      <ellipse cx="1080" cy="1300" rx="220" ry="160" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="1080" cy="1300" rx="166" ry="120" stroke-width="1.5" opacity="0.16"/>
      <ellipse cx="1080" cy="1300" rx="114" ry="80"  stroke-width="1"   opacity="0.14"/>
      <ellipse cx="1080" cy="1300" rx="64"  ry="42"  stroke-width="1"   opacity="0.14"/>

      <!-- Bottom-left companion -->
      <ellipse cx="120"  cy="1880" rx="240" ry="180" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="120"  cy="1880" rx="182" ry="136" stroke-width="1.5" opacity="0.16"/>
      <ellipse cx="120"  cy="1880" rx="126" ry="92"  stroke-width="1"   opacity="0.14"/>
      <ellipse cx="120"  cy="1880" rx="72"  ry="50"  stroke-width="1"   opacity="0.14"/>
      <ellipse cx="120"  cy="1880" rx="32"  ry="22"  stroke-width="1.5" opacity="0.17"/>

      <!-- ═══ ZONE 4 — Currently / Contact (y: 2000–3200) ═══ -->
      <!-- Right far peak -->
      <ellipse cx="1150" cy="2300" rx="350" ry="250" stroke-width="1"   opacity="0.15"/>
      <ellipse cx="1150" cy="2300" rx="278" ry="196" stroke-width="1.5" opacity="0.17"/>
      <ellipse cx="1150" cy="2300" rx="208" ry="144" stroke-width="1"   opacity="0.15"/>
      <ellipse cx="1150" cy="2300" rx="140" ry="94"  stroke-width="1"   opacity="0.15"/>
      <ellipse cx="1150" cy="2300" rx="76"  ry="48"  stroke-width="1.5" opacity="0.18"/>

      <!-- Center-left small -->
      <ellipse cx="300"  cy="2600" rx="180" ry="130" stroke-width="1"   opacity="0.13"/>
      <ellipse cx="300"  cy="2600" rx="134" ry="96"  stroke-width="1.5" opacity="0.15"/>
      <ellipse cx="300"  cy="2600" rx="90"  ry="62"  stroke-width="1"   opacity="0.13"/>
      <ellipse cx="300"  cy="2600" rx="48"  ry="32"  stroke-width="1"   opacity="0.13"/>

      <!-- Bottom-right closing peak -->
      <ellipse cx="1000" cy="3050" rx="380" ry="260" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="1000" cy="3050" rx="304" ry="206" stroke-width="1.5" opacity="0.16"/>
      <ellipse cx="1000" cy="3050" rx="228" ry="152" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="1000" cy="3050" rx="156" ry="102" stroke-width="1"   opacity="0.14"/>
      <ellipse cx="1000" cy="3050" rx="88"  ry="56"  stroke-width="1.5" opacity="0.17"/>
      <ellipse cx="1000" cy="3050" rx="38"  ry="24"  stroke-width="1"   opacity="0.14"/>
    </g>
  </svg>
</div>
