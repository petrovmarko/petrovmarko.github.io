---
const groups = [
  { label: 'Languages',  items: ['Python', 'C++', 'C', 'Java', 'JavaScript'] },
  { label: 'ML / Data',  items: ['PyTorch', 'TensorFlow', 'scikit-learn', 'Pandas', 'OpenCV'] },
  { label: 'Tools',      items: ['Linux', 'Git'] },
];
---

<section id="tools">
  <h1 class="section-heading">Tools:</h1>
  <ul class="tools-list">
    {groups.map(g => (
      <li>
        <strong>{g.label}:</strong> {g.items.join(', ')}.
      </li>
    ))}
  </ul>
</section>

<style>
  .tools-list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
  }
  .tools-list li {
    padding: 0.25rem 0;
    color: #252a2e;
    line-height: 1.55;
  }
  .tools-list strong {
    font-weight: 600;
  }
</style>
