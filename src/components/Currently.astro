---
const items = [
  {
    label: 'Building',
    text: 'MarkGrad — an autograd engine from scratch.',
    href: 'https://github.com/petrovmarko/MarkGrad',
  },
  {
    label: 'Competing',
    text: 'BirdCLEF+ 2026 on Kaggle — bioacoustic species classification.',
    href: 'https://www.kaggle.com/competitions/birdclef-2026/overview',
  },
  {
    label: 'Studying',
    text: 'Deep learning architectures and theory; competitive algorithms and data structures.',
  },
  {
    label: 'Interested in',
    text: 'Startups and company building, financial markets and quantitative thinking, puzzles of every kind.',
  },
];
---

<section id="now">
  <h1 class="section-heading">Now:</h1>
  <ul class="now-list">
    {items.map(item => (
      <li>
        <strong>{item.label}:</strong>{' '}
        {item.href
          ? <a href={item.href} target="_blank" rel="noreferrer">{item.text}</a>
          : <span>{item.text}</span>
        }
      </li>
    ))}
  </ul>
</section>

<style>
  .now-list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
  }
  .now-list li {
    padding: 0.25rem 0;
    color: #252a2e;
    line-height: 1.55;
  }
  .now-list strong {
    font-weight: 600;
    color: #252a2e;
  }
</style>
